rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function shortString(value, maximum) {
      return value is string && value.size() > 0 && value.size() <= maximum;
    }

    function optionalString(data, key, maximum) {
      return !(key in data) ||
        (data[key] is string && data[key].size() <= maximum);
    }

    function validProfile(data, userId) {
      return data.keys().hasAll([
          'id', 'displayName', 'avatarUrl', 'bio', 'createdAt', 'updatedAt'
        ]) &&
        data.keys().hasOnly([
          'id', 'displayName', 'avatarUrl', 'bio', 'createdAt', 'updatedAt'
        ]) &&
        data.id == userId &&
        shortString(data.displayName, 80) &&
        (data.avatarUrl == null ||
          (data.avatarUrl is string && data.avatarUrl.size() <= 2048)) &&
        data.bio is string && data.bio.size() <= 280 &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp;
    }

    function validLocation(location) {
      return location is map &&
        location.keys().hasAll(['latitude', 'longitude', 'placeName']) &&
        location.keys().hasOnly(['latitude', 'longitude', 'placeName', 'farmName', 'farmId', 'source']) &&
        location.latitude is number &&
        location.latitude >= -90 && location.latitude <= 90 &&
        location.longitude is number &&
        location.longitude >= -180 && location.longitude <= 180 &&
        shortString(location.placeName, 160) &&
        optionalString(location, 'farmName', 200) &&
        optionalString(location, 'farmId', 240) &&
        (!('source' in location) ||
          (location.source is map &&
            location.source.keys().hasAll(['provider', 'featureId', 'label']) &&
            location.source.keys().hasOnly(['provider', 'featureId', 'label']) &&
            location.source.provider == 'esri' &&
            shortString(location.source.featureId, 240) &&
            shortString(location.source.label, 240)));
    }

    function validWeapon(weapon) {
      return weapon is map &&
        shortString(weapon.model, 120) &&
        ((weapon.type == 'rifle' &&
            weapon.keys().hasAll(['type', 'model', 'caliber']) &&
            weapon.keys().hasOnly(['type', 'model', 'caliber']) &&
            shortString(weapon.caliber, 80)) ||
          (weapon.type == 'bow' &&
            weapon.keys().hasAll(['type', 'model', 'bowType']) &&
            weapon.keys().hasOnly(['type', 'model', 'bowType']) &&
            shortString(weapon.bowType, 80)));
    }

    function validAmmunition(ammunition) {
      return ammunition is map &&
        ammunition.keys().hasAll(['grain']) &&
        ammunition.keys().hasOnly(['grain', 'brand', 'detail']) &&
        ammunition.grain is number &&
        ammunition.grain > 0 && ammunition.grain <= 2000 &&
        optionalString(ammunition, 'brand', 100) &&
        optionalString(ammunition, 'detail', 160);
    }

    function validMeasurement(value) {
      return value is map &&
        value.keys().hasOnly(['score', 'scoreUnit', 'scoringSystem', 'weightDressed', 'weightUndressed', 'weightUnit']) &&
        (!('score' in value) || (value.score is number && value.score > 0)) &&
        optionalString(value, 'scoreUnit', 40) &&
        optionalString(value, 'scoringSystem', 80) &&
        (!('weightDressed' in value) || (value.weightDressed is number && value.weightDressed > 0)) &&
        (!('weightUndressed' in value) || (value.weightUndressed is number && value.weightUndressed > 0)) &&
        (!('weightUnit' in value) || value.weightUnit in ['kg', 'lb']);
    }

    function validAttachment(value) {
      return value is map && value.keys().hasAll(['name']) &&
        value.keys().hasOnly(['name', 'detail', 'grain']) && shortString(value.name, 120) &&
        optionalString(value, 'detail', 160) &&
        (!('grain' in value) ||
          (value.grain is number && value.grain > 0 && value.grain <= 2000));
    }

    function validAttachments(value) {
      return value is map && value.keys().hasOnly(['optic', 'suppressor', 'bipod', 'sling', 'arrow', 'broadhead']) &&
        (!('optic' in value) || validAttachment(value.optic)) &&
        (!('suppressor' in value) || validAttachment(value.suppressor)) &&
        (!('bipod' in value) || validAttachment(value.bipod)) &&
        (!('sling' in value) || validAttachment(value.sling)) &&
        (!('arrow' in value) || validAttachment(value.arrow)) &&
        (!('broadhead' in value) || validAttachment(value.broadhead));
    }

    function validBounds(bounds) {
      return bounds is map &&
        bounds.keys().hasAll(['south', 'west', 'north', 'east']) &&
        bounds.keys().hasOnly(['south', 'west', 'north', 'east']) &&
        bounds.south is number && bounds.south >= -90 && bounds.south <= 90 &&
        bounds.north is number && bounds.north >= -90 && bounds.north <= 90 &&
        bounds.west is number && bounds.west >= -180 && bounds.west <= 180 &&
        bounds.east is number && bounds.east >= -180 && bounds.east <= 180 &&
        bounds.south <= bounds.north;
    }

    function validRoute(route, userId, killId) {
      return route is map &&
        route.keys().hasAll([
          'storagePath', 'fileName', 'distanceKm', 'durationMin', 'bounds',
          'sourceHash'
        ]) &&
        route.keys().hasOnly([
          'storagePath', 'fileName', 'distanceKm', 'durationMin', 'bounds',
          'sourceHash'
        ]) &&
        shortString(route.storagePath, 512) &&
        route.storagePath.matches(
          '^users/' + userId + '/kills/' + killId + '/routes/[^/]+[.]gpx$'
        ) &&
        shortString(route.fileName, 180) &&
        route.distanceKm is number && route.distanceKm >= 0 &&
        (route.durationMin == null ||
          (route.durationMin is number && route.durationMin >= 0)) &&
        validBounds(route.bounds) &&
        shortString(route.sourceHash, 128);
    }

    function validKill(data, userId, killId) {
      return data.keys().hasAll([
          'id', 'ownerId', 'species', 'coverMediaId', 'media', 'country',
          'date', 'killTime', 'location', 'weapon', 'ammunition', 'route',
          'description', 'status', 'createdAt', 'updatedAt', 'trashedAt'
        ]) &&
        data.keys().hasOnly([
          'id', 'ownerId', 'species', 'coverMediaId', 'media', 'country',
          'date', 'killTime', 'location', 'weapon', 'ammunition', 'route',
          'description', 'status', 'createdAt', 'updatedAt', 'trashedAt',
          'measurement', 'loadoutId', 'equipmentAttachments', 'isPublic'
        ]) &&
        data.id == killId &&
        data.ownerId == userId &&
        shortString(data.species, 120) &&
        (data.coverMediaId == null || shortString(data.coverMediaId, 128)) &&
        data.media is list && data.media.size() <= 30 &&
        shortString(data.country, 100) &&
        data.date is string &&
        data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
        data.killTime is string &&
        data.killTime.matches('^([01]\\d|2[0-3]):[0-5]\\d$') &&
        validLocation(data.location) &&
        validWeapon(data.weapon) &&
        validAmmunition(data.ammunition) &&
        (!('measurement' in data) || validMeasurement(data.measurement)) &&
        optionalString(data, 'loadoutId', 128) &&
        (!('equipmentAttachments' in data) || validAttachments(data.equipmentAttachments)) &&
        (!('isPublic' in data) || data.isPublic is bool) &&
        (data.route == null || validRoute(data.route, userId, killId)) &&
        data.description is string && data.description.size() <= 5000 &&
        data.status in ['draft', 'active', 'trashed'] &&
        (data.status == 'draft' || data.coverMediaId is string) &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp &&
        ((data.status == 'trashed' && data.trashedAt is timestamp) ||
          (data.status != 'trashed' && data.trashedAt == null));
    }

    function validArmoryItem(data, userId, itemId) {
      return data.keys().hasAll(['id', 'ownerId', 'name', 'kind', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['id', 'ownerId', 'name', 'kind', 'weapon', 'grain', 'detail', 'createdAt', 'updatedAt']) &&
        data.id == itemId && data.ownerId == userId && shortString(data.name, 120) &&
        data.kind in ['weapon', 'optic', 'suppressor', 'bipod', 'sling', 'ammunition', 'arrow', 'broadhead'] &&
        optionalString(data, 'detail', 160) &&
        ((data.kind == 'weapon' && 'weapon' in data && validWeapon(data.weapon)) ||
          (data.kind in ['ammunition', 'broadhead'] && 'grain' in data && data.grain is number && data.grain > 0 && data.grain <= 2000) ||
          data.kind in ['optic', 'suppressor', 'bipod', 'sling', 'arrow']) &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validLoadout(data, userId, loadoutId) {
      return data.keys().hasAll(['id', 'ownerId', 'name', 'weaponId', 'slots', 'isDefault', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['id', 'ownerId', 'name', 'weaponId', 'slots', 'isDefault', 'createdAt', 'updatedAt']) &&
        data.id == loadoutId && data.ownerId == userId && shortString(data.name, 120) &&
        shortString(data.weaponId, 128) && data.slots is map &&
        data.slots.keys().hasOnly(['opticId', 'suppressorId', 'bipodId', 'slingId', 'ammunitionId', 'arrowId', 'broadheadId']) &&
        optionalString(data.slots, 'opticId', 128) && optionalString(data.slots, 'suppressorId', 128) &&
        optionalString(data.slots, 'bipodId', 128) && optionalString(data.slots, 'slingId', 128) &&
        optionalString(data.slots, 'ammunitionId', 128) && optionalString(data.slots, 'arrowId', 128) &&
        optionalString(data.slots, 'broadheadId', 128) && data.isDefault is bool &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validPublicProfile(data, userId) {
      return data.keys().hasAll(['id', 'displayName', 'avatarUrl', 'bio', 'searchName', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['id', 'displayName', 'avatarUrl', 'bio', 'searchName', 'createdAt', 'updatedAt']) &&
        data.id == userId && shortString(data.displayName, 80) && shortString(data.searchName, 100) &&
        (data.avatarUrl == null || (data.avatarUrl is string && data.avatarUrl.size() <= 2048)) &&
        data.bio is string && data.bio.size() <= 280 && data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validPublicHunt(data, publicHuntId) {
      return data.keys().hasAll(['id', 'ownerId', 'sourceKillId', 'hunter', 'species', 'coverMediaId', 'media', 'country', 'date', 'killTime', 'location', 'weapon', 'ammunition', 'routeSummary', 'description', 'publishedAt', 'updatedAt']) &&
        data.keys().hasOnly(['id', 'ownerId', 'sourceKillId', 'hunter', 'species', 'coverMediaId', 'media', 'country', 'date', 'killTime', 'location', 'weapon', 'ammunition', 'equipmentAttachments', 'measurement', 'routeSummary', 'description', 'publishedAt', 'updatedAt']) &&
        data.id == publicHuntId && data.ownerId == request.auth.uid && shortString(data.sourceKillId, 128) &&
        data.hunter is map && data.hunter.id == data.ownerId && shortString(data.hunter.displayName, 80) &&
        shortString(data.species, 120) && data.media is list && data.media.size() <= 30 && shortString(data.country, 100) &&
        validLocation(data.location) && validWeapon(data.weapon) && validAmmunition(data.ammunition) &&
        (!('farmId' in data.location) ||
          exists(/databases/$(database)/documents/farms/$(data.location.farmId))) &&
        (!('measurement' in data) || validMeasurement(data.measurement)) &&
        (!('equipmentAttachments' in data) || validAttachments(data.equipmentAttachments)) &&
        data.description is string && data.description.size() <= 5000 && data.publishedAt is timestamp && data.updatedAt is timestamp;
    }

    function validFarm(data, farmId) {
      return data.keys().hasAll(['id', 'name', 'searchName', 'latitude', 'longitude', 'country', 'placeName', 'createdBy', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['id', 'name', 'searchName', 'latitude', 'longitude', 'country', 'placeName', 'createdBy', 'createdAt', 'updatedAt']) &&
        data.id == farmId && data.createdBy == request.auth.uid &&
        shortString(data.name, 200) && shortString(data.searchName, 200) &&
        data.searchName == data.searchName.lower() &&
        data.latitude is number && data.latitude >= -90 && data.latitude <= 90 &&
        data.longitude is number && data.longitude >= -180 && data.longitude <= 180 &&
        shortString(data.country, 100) && shortString(data.placeName, 160) &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validHuntLike(data, publicHuntId, likerId) {
      return data.keys().hasAll(['huntId', 'likerId', 'likerName', 'createdAt']) &&
        data.keys().hasOnly(['huntId', 'likerId', 'likerName', 'createdAt']) &&
        data.huntId == publicHuntId && data.likerId == likerId &&
        data.likerId == request.auth.uid && shortString(data.likerName, 80) &&
        data.createdAt is timestamp;
    }

    function validHuntComment(data, publicHuntId, commentId) {
      return data.keys().hasAll(['id', 'huntId', 'authorId', 'authorName', 'body', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['id', 'huntId', 'authorId', 'authorName', 'body', 'createdAt', 'updatedAt']) &&
        data.id == commentId && data.huntId == publicHuntId &&
        data.authorId == request.auth.uid && shortString(data.authorName, 80) &&
        shortString(data.body, 1000) &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    // Notifications are written by the actor into the recipient's inbox, in
    // the same batch as the triggering action. existsAfter() proves the
    // backing follow/like/comment really exists, so an actor cannot fabricate
    // activity that never happened.
    function validNotification(data, userId, notificationId) {
      return data.keys().hasAll(['id', 'recipientId', 'actorId', 'actorName', 'type', 'createdAt', 'readAt']) &&
        data.keys().hasOnly(['id', 'recipientId', 'actorId', 'actorName', 'type', 'huntId', 'huntSpecies', 'commentId', 'preview', 'createdAt', 'readAt']) &&
        data.id == notificationId && data.recipientId == userId &&
        data.actorId == request.auth.uid && shortString(data.actorName, 80) &&
        optionalString(data, 'huntId', 128) && optionalString(data, 'huntSpecies', 120) &&
        optionalString(data, 'commentId', 128) && optionalString(data, 'preview', 140) &&
        data.createdAt is timestamp && data.readAt == null &&
        ((data.type == 'follow' &&
            existsAfter(/databases/$(database)/documents/publicFollowers/$(userId)/followers/$(request.auth.uid))) ||
          (data.type == 'like' && 'huntId' in data &&
            existsAfter(/databases/$(database)/documents/publicHunts/$(data.huntId)/likes/$(request.auth.uid))) ||
          (data.type == 'comment' && 'huntId' in data && 'commentId' in data &&
            existsAfter(/databases/$(database)/documents/publicHunts/$(data.huntId)/comments/$(data.commentId))));
    }

    function validForumQuestion(data, questionId) {
      return data.keys().hasAll(['id', 'authorId', 'authorName', 'title', 'body', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['id', 'authorId', 'authorName', 'title', 'body', 'tags', 'acceptedAnswerId', 'createdAt', 'updatedAt']) &&
        data.id == questionId && data.authorId == request.auth.uid &&
        shortString(data.authorName, 80) && shortString(data.title, 160) &&
        shortString(data.body, 5000) &&
        (!('tags' in data) || (data.tags is list && data.tags.size() <= 5)) &&
        optionalString(data, 'acceptedAnswerId', 128) &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validForumAnswer(data, questionId, answerId) {
      return data.keys().hasAll(['id', 'questionId', 'authorId', 'authorName', 'body', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['id', 'questionId', 'authorId', 'authorName', 'body', 'createdAt', 'updatedAt']) &&
        data.id == answerId && data.questionId == questionId &&
        data.authorId == request.auth.uid &&
        shortString(data.authorName, 80) && shortString(data.body, 5000) &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validFollow(data, followerId, followedId) {
      return data.keys().hasAll(['followerId', 'followedId', 'createdAt']) &&
        data.keys().hasOnly(['followerId', 'followedId', 'createdAt']) &&
        data.followerId == followerId && data.followedId == followedId && followerId != followedId && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if owns(userId);
      allow create: if owns(userId) &&
        validProfile(request.resource.data, userId);
      allow update: if owns(userId) &&
        validProfile(request.resource.data, userId) &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.createdAt == resource.data.createdAt;
      // Owner-only delete exists solely for account deletion. In-app removal
      // of records goes through the trash status, not document deletion.
      allow delete: if owns(userId);

      match /kills/{killId} {
        allow read: if owns(userId);
        allow create: if owns(userId) &&
          validKill(request.resource.data, userId, killId);
        allow update: if owns(userId) &&
          validKill(request.resource.data, userId, killId) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.ownerId == resource.data.ownerId &&
          request.resource.data.createdAt == resource.data.createdAt;
        // Owner-only delete exists solely for account deletion (see above).
        allow delete: if owns(userId);
      }

      match /armoryItems/{itemId} {
        allow read: if owns(userId);
        allow create: if owns(userId) && validArmoryItem(request.resource.data, userId, itemId);
        allow update: if owns(userId) && validArmoryItem(request.resource.data, userId, itemId) &&
          request.resource.data.id == resource.data.id && request.resource.data.ownerId == resource.data.ownerId &&
          request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if owns(userId);
      }

      match /loadouts/{loadoutId} {
        allow read: if owns(userId);
        allow create: if owns(userId) && validLoadout(request.resource.data, userId, loadoutId);
        allow update: if owns(userId) && validLoadout(request.resource.data, userId, loadoutId) &&
          request.resource.data.id == resource.data.id && request.resource.data.ownerId == resource.data.ownerId &&
          request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if owns(userId);
      }

      match /following/{followedId} {
        allow read: if owns(userId);
        allow create, update, delete: if owns(userId) &&
          (request.method == 'delete' || validFollow(request.resource.data, userId, followedId));
      }

      match /notifications/{notificationId} {
        allow read: if owns(userId);
        allow create: if signedIn() && request.auth.uid != userId &&
          validNotification(request.resource.data, userId, notificationId) &&
          request.resource.data.createdAt < request.time + duration.value(10, 'm');
        // The recipient may only mark a notification read.
        allow update: if owns(userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']) &&
          request.resource.data.readAt is timestamp;
        // The recipient clears their inbox; the actor retracts the
        // notification on unlike/unfollow. Deleting a nonexistent document is
        // a harmless no-op and must not fail those batched retractions.
        allow delete: if owns(userId) ||
          (signedIn() && (resource == null || resource.data.actorId == request.auth.uid));
      }
    }

    match /publicProfiles/{userId} {
      allow read: if true;
      allow create, update: if owns(userId) && validPublicProfile(request.resource.data, userId);
      allow delete: if owns(userId);
    }

    match /publicHunts/{publicHuntId} {
      allow read: if true;
      allow create, update: if signedIn() && validPublicHunt(request.resource.data, publicHuntId);
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;

      match /likes/{likerId} {
        allow read: if true;
        allow create: if signedIn() && validHuntLike(request.resource.data, publicHuntId, likerId) &&
          request.resource.data.createdAt < request.time + duration.value(10, 'm') &&
          exists(/databases/$(database)/documents/publicHunts/$(publicHuntId));
        // The liker removes their own like; the hunt owner clears likes when
        // unpublishing (while the hunt document still exists).
        allow delete: if signedIn() && (request.auth.uid == likerId ||
          get(/databases/$(database)/documents/publicHunts/$(publicHuntId)).data.ownerId == request.auth.uid);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn() && validHuntComment(request.resource.data, publicHuntId, commentId) &&
          request.resource.data.createdAt < request.time + duration.value(10, 'm') &&
          exists(/databases/$(database)/documents/publicHunts/$(publicHuntId));
        allow update: if signedIn() && resource.data.authorId == request.auth.uid &&
          validHuntComment(request.resource.data, publicHuntId, commentId) &&
          request.resource.data.createdAt == resource.data.createdAt;
        // The comment author removes their own comment; the hunt owner
        // moderates comments on their own hunt and clears them on unpublish.
        allow delete: if signedIn() && (resource.data.authorId == request.auth.uid ||
          get(/databases/$(database)/documents/publicHunts/$(publicHuntId)).data.ownerId == request.auth.uid);
      }
    }

    match /farms/{farmId} {
      // Community farm directory. Entries are created only at publish time by
      // the publishing client; they are immutable from clients afterwards so
      // no user can move or rename another hunter's farm pin. Owner claims and
      // corrections arrive later through moderated/admin paths.
      allow read: if true;
      allow create: if signedIn() && validFarm(request.resource.data, farmId);
      allow update, delete: if false;
    }

    // Community Q&A forum. Readable by any signed-in hunter; every document
    // is writable only by its author (validForum* pins authorId to the
    // caller). Accepting an answer is a question update, so only the question
    // author can set acceptedAnswerId.
    match /forumQuestions/{questionId} {
      allow read: if signedIn();
      // The createdAt bound blocks pinning a post to the top of the
      // newest-first feed with a spoofed future timestamp.
      allow create: if signedIn() && validForumQuestion(request.resource.data, questionId) &&
        request.resource.data.createdAt < request.time + duration.value(10, 'm');
      allow update: if signedIn() && resource.data.authorId == request.auth.uid &&
        validForumQuestion(request.resource.data, questionId) &&
        request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if signedIn() && resource.data.authorId == request.auth.uid;

      match /answers/{answerId} {
        allow read: if signedIn();
        allow create: if signedIn() && validForumAnswer(request.resource.data, questionId, answerId) &&
          request.resource.data.createdAt < request.time + duration.value(10, 'm') &&
          exists(/databases/$(database)/documents/forumQuestions/$(questionId));
        allow update: if signedIn() && resource.data.authorId == request.auth.uid &&
          validForumAnswer(request.resource.data, questionId, answerId) &&
          request.resource.data.createdAt == resource.data.createdAt;
        // The answer author removes their own answer; the question author may
        // also clear answers under their question (question deletion cleanup).
        allow delete: if signedIn() && (resource.data.authorId == request.auth.uid ||
          get(/databases/$(database)/documents/forumQuestions/$(questionId)).data.authorId == request.auth.uid);
      }
    }

    // Collection-group read for follow edges so a profile can list who a
    // hunter follows (publicFollowers/*/followers where followerId == uid).
    // Only publicFollowers has a subcollection named `followers`, and its
    // edges are public by design. Grants read only — writes are governed by
    // the specific match below.
    match /{path=**}/followers/{followerId} {
      allow read: if true;
    }

    match /publicFollowers/{followedId}/followers/{followerId} {
      allow read: if true;
      allow create, update: if signedIn() && request.auth.uid == followerId &&
        validFollow(request.resource.data, followerId, followedId);
      // The follower removes their own edge; the followed account may also
      // clear its own followers list (account deletion).
      allow delete: if signedIn() &&
        (request.auth.uid == followerId || request.auth.uid == followedId);
    }
  }
}
